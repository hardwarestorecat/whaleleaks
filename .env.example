# ──────────────────────────────────────────────
# whaleleaks configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# === Thresholds ===
WHALE_THRESHOLD_USD=3000       # Discord alert when a single order exceeds this
FLOW_THRESHOLD_USD=50          # Show in flow panel (no alert)

# === Redis ===
# When running via docker compose, use: redis://redis:6379
# When running locally: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# === Database ===
# When running via docker compose, use: /app/data/whaleleaks.db
# When running locally, leave unset (defaults to whaleleaks.db in project root)
# DB_PATH=/app/data/whaleleaks.db

# ─────────────────────────────────────────────
# === Discord webhook ===
# Setup (~30 seconds):
#   1. Open your Discord server
#   2. Server Settings → Integrations → Webhooks → New Webhook
#   3. Pick a channel, click "Copy Webhook URL", paste below
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# ─────────────────────────────────────────────
# === Email (SMTP) — optional ===
EMAIL_ENABLED=false
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=you@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=you@gmail.com
EMAIL_TO=you@gmail.com

# ─────────────────────────────────────────────
# === Polygon / Polymarket ===
POLYGON_RPC_URL=https://rpc.ankr.com/polygon

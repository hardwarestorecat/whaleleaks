# ──────────────────────────────────────────────
# whaleleaks configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# === Thresholds ===
WHALE_THRESHOLD_USD=5000          # Alert when a single order exceeds this value
PROPORTIONAL_FACTOR=0.01          # Auto-trade size = whale_qty × this (0.01 = 1%)
AUTO_TRADE_ENABLED=true           # Set false to alert-only, no order placement

# === Geopolitical keywords (comma-separated, case-insensitive, word-boundary matched) ===
GEOPOLITICAL_KEYWORDS=war,president,nato,tariff,election,treaty,sanction,military,nuclear,invasion,coup,ceasefire,diplomat,congress,senate,fed,ukraine,russia,china,taiwan,iran

# ─────────────────────────────────────────────
# === Kalshi ===
# Generate at https://kalshi.com/profile/api
# Download the RSA private key and put path below
KALSHI_API_KEY=your_kalshi_api_key_here
KALSHI_PRIVATE_KEY_PATH=kalshi_private_key.pem

# ─────────────────────────────────────────────
# === Discord webhook ===
# Setup (~30 seconds):
#   1. Open your Discord server (or DM yourself via a private server)
#   2. Server Settings → Integrations → Webhooks → New Webhook
#   3. Pick a channel, click "Copy Webhook URL", paste below
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# ─────────────────────────────────────────────
# === Email (SMTP) — optional ===
EMAIL_ENABLED=false
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=you@gmail.com
EMAIL_PASSWORD=your_app_password   # Gmail: use App Password, not account password
EMAIL_FROM=you@gmail.com
EMAIL_TO=you@gmail.com,other@example.com

# ─────────────────────────────────────────────
# === Web Push — optional (requires a service worker on a web app) ===
PUSH_ENABLED=false
PUSH_VAPID_PRIVATE_KEY=your_vapid_private_key
PUSH_VAPID_CLAIMS_SUB=mailto:you@example.com
PUSH_SUBSCRIPTION_ENDPOINT=https://fcm.googleapis.com/fcm/send/...
PUSH_SUBSCRIPTION_P256DH=your_p256dh_key
PUSH_SUBSCRIPTION_AUTH=your_auth_secret

# ─────────────────────────────────────────────
# === Polygon / Polymarket ===
# Free public RPC works but Alchemy/Infura is more reliable for production
POLYGON_RPC_URL=https://polygon-rpc.com
# For WebSocket real-time (faster than polling):
# POLYGON_RPC_URL=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
